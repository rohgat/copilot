# ── Identity ──────────────────────────────────────────────────────────────
USER_NAME=Rohit
USER_PHONE=+919xxxxxxxxx       # Your WhatsApp number (E.164 format)

# ── API Keys ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
NOTION_TOKEN=ntn_...
NOTION_DATABASE_ID=           # Auto-filled after first run

# ── Audio ──────────────────────────────────────────────────────────────────
AUDIO_DEVICE_NAME=BlackHole 2ch
WHISPER_MODEL=large-v3        # or medium for faster response

# ── Tuning ─────────────────────────────────────────────────────────────────
SILENCE_THRESHOLD_DB=-45      # dB below which counts as silence
SILENCE_DURATION_SECONDS=60   # seconds of silence before auto-end

# ── Ports ─────────────────────────────────────────────────────────────────
WHATSAPP_BRIDGE_PORT=3001
DASHBOARD_PORT=8000
